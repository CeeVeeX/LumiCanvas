<Window
    x:Class="LumiCanvas.CanvasWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LumiCanvas Canvas">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border
            x:Name="CanvasViewport"
            Margin="0"
            BorderBrush="#18FFFFFF"
            BorderThickness="0"
            CornerRadius="0"
            DoubleTapped="CanvasViewport_DoubleTapped"
            PointerMoved="CanvasViewport_PointerMoved"
            PointerPressed="CanvasViewport_PointerPressed"
            PointerReleased="CanvasViewport_PointerReleased"
            PointerWheelChanged="CanvasViewport_PointerWheelChanged"
            RightTapped="CanvasViewport_RightTapped">
            <Border.Background>
                <SolidColorBrush Color="#1A0F141B" />
            </Border.Background>
            <Grid>
                <Rectangle IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#18000000" Offset="0" />
                            <GradientStop Color="#06000000" Offset="0.4" />
                            <GradientStop Color="#14000000" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Canvas x:Name="BoardCanvas" Background="Transparent" Height="20000" Width="20000">
                    <Canvas.RenderTransform>
                        <CompositeTransform x:Name="BoardTransform" />
                    </Canvas.RenderTransform>
                </Canvas>

                <Rectangle
                    x:Name="SelectionMarquee"
                    Visibility="Collapsed"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Stroke="#CC8CC4FF"
                    StrokeThickness="1"
                    StrokeDashArray="4,4"
                    Fill="#228CC4FF" />

                <Border
                    Margin="16"
                    Padding="12,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#6618212C"
                    BorderThickness="0"
                    CornerRadius="14">
                    <StackPanel Spacing="2">
                        <TextBlock
                            x:Name="CurrentTaskTitleText"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="&#x672A;&#x9009;&#x62E9;&#x4EFB;&#x52A1;" />
                        <TextBlock
                            Foreground="#8FA0B6"
                            Text="&#x53CC;&#x51FB;&#x7A7A;&#x767D;&#x521B;&#x5EFA;&#x6587;&#x672C;&#xFF0C;&#x53F3;&#x952E;&#x7A7A;&#x767D;&#x6DFB;&#x52A0;&#x6587;&#x4EF6;&#x6216;&#x6587;&#x4EF6;&#x5939;" />
                        <TextBlock
                            Foreground="#6F7C8E"
                            Text="Ctrl + Tab &#x53EF;&#x56DE;&#x5230;&#x4FA7;&#x8FB9;&#x680F;" />
                    </StackPanel>
                </Border>

                <Button
                    Margin="16"
                    MinWidth="40"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="CloseCanvasButton_Click">
                    <FontIcon Glyph="&#xE711;" />
                </Button>

                <Border
                    x:Name="EmptyBoardHintCard"
                    Width="360"
                    Padding="20"
                    Margin="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#7018212C"
                    BorderThickness="0"
                    CornerRadius="18">
                    <StackPanel Spacing="10">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="&#x5148;&#x4ECE;&#x4FA7;&#x8FB9;&#x680F;&#x9009;&#x62E9;&#x4EFB;&#x52A1;" />
                        <TextBlock
                            TextWrapping="WrapWholeWords"
                            Foreground="#A9B6C8"
                            Text="&#x8FD9;&#x91CC;&#x662F;&#x72EC;&#x7ACB;&#x753B;&#x5E03;&#x7A97;&#x53E3;&#x3002;&#x53CC;&#x51FB;&#x7A7A;&#x767D;&#x5904;&#x521B;&#x5EFA;&#x6587;&#x672C;&#x7EC4;&#x4EF6;&#xFF0C;&#x53F3;&#x952E;&#x7A7A;&#x767D;&#x5904;&#x53EF;&#x6DFB;&#x52A0;&#x6587;&#x4EF6;&#x6216;&#x6587;&#x4EF6;&#x5939;&#x3002;&#x56FE;&#x7247;&#x548C;&#x89C6;&#x9891;&#x4F1A;&#x76F4;&#x63A5;&#x6E32;&#x67D3;&#xFF0C;&#x5176;&#x4ED6;&#x5185;&#x5BB9;&#x663E;&#x793A;&#x540D;&#x79F0;&#x3002;" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
